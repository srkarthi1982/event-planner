---
import { AvButton, AvCard, AvContainer } from "@ansiversa/components";
import AvMiniAppBar from "../components/AvMiniAppBar.astro";
import AppShell from "../layouts/AppShell.astro";

const title = "Event Planner | Ansiversa";
const description = "A calm, premium space to plan events, track tasks, and manage your guest list.";
---

<AppShell title={title} description={description}>
  <AvMiniAppBar title="Event Planner" />
  <main class="bg-slate-950 text-slate-100">
    <section class="border-b border-slate-800 py-20 sm:py-24">
      <AvContainer size="narrow" className="space-y-7 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-sky-300">Plan with confidence</p>
        <h1 class="text-4xl font-semibold leading-tight sm:text-5xl">One elegant place to run every event.</h1>
        <p class="mx-auto max-w-2xl text-slate-300">
          Event Planner gives you a clear plan, a reliable checklist, and a guest view you can trust — without clutter.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <AvButton href="/app">Open workspace</AvButton>
          <AvButton href="/app" variant="ghost">View your events</AvButton>
        </div>
      </AvContainer>
    </section>

    <section class="py-14">
      <AvContainer size="wide" className="grid gap-4 sm:grid-cols-3">
        <AvCard className="space-y-2 p-5">
          <h2 class="text-lg font-semibold text-white">Event basics</h2>
          <p class="text-sm text-slate-300">Capture title, type, schedule, location, and notes in one smooth flow.</p>
        </AvCard>
        <AvCard className="space-y-2 p-5">
          <h2 class="text-lg font-semibold text-white">Task tracking</h2>
          <p class="text-sm text-slate-300">Keep preparation visible with status, due dates, and completion progress.</p>
        </AvCard>
        <AvCard className="space-y-2 p-5">
          <h2 class="text-lg font-semibold text-white">Guest clarity</h2>
          <p class="text-sm text-slate-300">Manage invited, confirmed, maybe, and declined guests with clean context.</p>
        </AvCard>
      </AvContainer>
    </section>
  </main>
</AppShell>
