---
import { AvButton } from "@ansiversa/components";

interface Props {
  title?: string;
}

const { title = "Event Planner" } = Astro.props;
const rootUrl = Astro.locals.rootAppUrl ?? "https://ansiversa.com";
---

<header class="border-b border-slate-800 bg-slate-950/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Ansiversa Mini App</p>
      <h1 class="text-base font-semibold text-white sm:text-lg">{title}</h1>
    </div>
    <div class="flex items-center gap-2">
      <AvButton href={`${rootUrl}/dashboard`} variant="ghost" size="sm">Dashboard</AvButton>
      <AvButton href="/app" size="sm">Workspace</AvButton>
    </div>
  </div>
</header>
